<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".DetalhesFeiticoActivity">

    <TextView
        android:id="@+id/tvTituloDetalhes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/titulo_detalhes_feitico"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvNomeFeitico"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center"
        android:textSize="24sp"
        android:textStyle="bold"
        tools:text="Expecto Patronum" />

    <TextView
        android:id="@+id/tvDescricaoFeitico"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textSize="18sp"
        tools:text="Creates a silver patronus to drive away Dementors." />

</LinearLayout>
