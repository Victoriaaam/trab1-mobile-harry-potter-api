<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#FF2A2010" />
            <stroke android:width="1dp" android:color="@color/hufflepuff_border" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/hufflepuff_bg" />
            <stroke android:width="1dp" android:color="@color/hufflepuff_border" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
