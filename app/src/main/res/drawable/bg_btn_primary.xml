<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#FF3A2070"
                android:endColor="#FF5A35A0"
                android:angle="135" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient
                android:startColor="#FF4A2D8A"
                android:endColor="#FF7C4DFF"
                android:angle="135" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
