<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#FF1A1030" />
            <stroke android:width="1dp" android:color="@color/accent_purple" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="@color/accent_purple_dark" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
