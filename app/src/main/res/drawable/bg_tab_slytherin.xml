<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape>
            <solid android:color="@color/slytherin_border" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#FF152515" />
            <stroke android:width="1dp" android:color="@color/slytherin_border" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/slytherin_bg" />
            <stroke android:width="1dp" android:color="@color/slytherin_border" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</selector>
