<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#FF201840" />
            <stroke android:width="1dp" android:color="@color/accent_purple_dark" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/bg_card" />
            <stroke android:width="1dp" android:color="@color/bg_card_border" />
            <corners android:radius="12dp" />
        </shape>
    </item>
</selector>
